# VisionGuide - Exemplo de Configuração de API Keys

# Provedor de IA: 'gemini' ou 'openai'
AI_PROVIDER=openai

# OpenAI GPT-4 Vision (agora principal)
OPENAI_API_KEY=sua_chave_aqui

# Google Gemini AI (alternativa)
# GEMINI_API_KEY=sua_chave_aqui

# Opcionais - Outros serviços

# Replicate (acesso a diversos modelos de IA)
# REPLICATE_API_TOKEN=sua_chave_aqui

# Hugging Face (modelos open source)
# HUGGINGFACE_API_TOKEN=sua_chave_aqui

# Configurações do servidor
PORT=3001