# Configuração do Backend VisionGuide

# Porta do backend Python (FastAPI) — usada pelo app Flutter
PORT=3001

# Provedor de IA (openai ou deixar vazio para modo fallback)
AI_PROVIDER=openai

# Chave da API OpenAI (chat assistente visual)
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sua_chave_aqui

# Modelo do chat (padrão: gpt-4o-mini — suporta texto e visão)
OPENAI_MODEL=gpt-4o-mini

# Modelo opcional só para descrição de imagens (padrão: mesmo que OPENAI_MODEL)
# OPENAI_VISION_MODEL=gpt-4o-mini

# Sem OPENAI_API_KEY: apenas detecção YOLO; descrições detalhadas exigem a chave.

# Usuário de teste (criado ao iniciar o servidor Python)
# USUARIO_TESTE_EMAIL=teste@visionguide.com
# USUARIO_TESTE_SENHA=123456
# DESABILITAR_USUARIO_TESTE=false
